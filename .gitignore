# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# mobile signing keys + service account files (never commit)
*.p8
*.keystore
*.jks
keystore.properties
android/app/google-services.json
ios/App/GoogleService-Info.plist

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# @capacitor/assets writes a PWA icon set here as a side effect of
# `npm run mobile:assets`. The icons the app actually serves live in
# public/icons/ — this directory isn't served by Next and isn't used.
/icons/

# typescript
*.tsbuildinfo
next-env.d.ts

!.env.example

# one-time migration scripts
/scripts/migrate-to-multi-school.ts
/scripts/run-migration.ts
/scripts/README-MIGRATION.md

# claude code instructions
claude_code_instruction/*
